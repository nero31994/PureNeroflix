<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/iptv_player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        app:resize_mode="fill" />

    <!-- Buffering / loading indicator (shown by ExoPlayer listener) -->
    <ProgressBar
        android:id="@+id/iptv_loading"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerInParent="true"
        android:indeterminateTint="@color/neon_red"
        android:visibility="gone" />

    <!-- Top bar (auto-hides) -->
    <LinearLayout
        android:id="@+id/iptv_top_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#CC000000">

        <TextView
            android:id="@+id/iptv_back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="8dp"
            android:focusable="true"
            android:background="@drawable/nav_item_focus_bg" />

        <TextView
            android:id="@+id/iptv_current_channel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Select a channel"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/iptv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Channel sidebar (auto-hides, right side) -->
    <LinearLayout
        android:id="@+id/iptv_sidebar"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:orientation="vertical"
        android:background="#CC111111">

        <!-- Sidebar header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#CC000000">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CHANNELS"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="#1A1A1A">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="14sp"
                android:paddingEnd="8dp" />

            <EditText
                android:id="@+id/iptv_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search channels..."
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:maxLines="1"
                android:imeOptions="actionSearch"
                android:inputType="text" />

        </LinearLayout>

        <!-- Group / category tabs (populated dynamically) -->
        <HorizontalScrollView
            android:id="@+id/iptv_group_scroll"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:scrollbars="none"
            android:background="#161616"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/iptv_group_tabs"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

        </HorizontalScrollView>

        <!-- Channel list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/iptv_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none" />

    </LinearLayout>

</RelativeLayout>
