<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/iptv_player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        app:resize_mode="fill" />

    <ProgressBar
        android:id="@+id/iptv_loading"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerInParent="true"
        android:indeterminateTint="@color/neon_red"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/iptv_top_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#CC000000">

        <TextView
            android:id="@+id/iptv_back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="8dp"
            android:focusable="true"
            android:background="@drawable/nav_item_focus_bg" />

        <TextView
            android:id="@+id/iptv_current_channel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Select a channel"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/iptv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- FULL SCREEN EPG GUIDE (auto-hides) -->
    <LinearLayout
        android:id="@+id/iptv_sidebar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#EE0D0D0D">

        <!-- Guide header: search + current date/time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#CC000000">

            <TextView
                android:id="@+id/iptv_guide_back_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back to Movies"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:padding="8dp"
                android:focusable="true"
                android:background="@drawable/nav_item_focus_bg"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:id="@+id/epg_date_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guide"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/iptv_search"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="20dp"
                android:hint="🔍 Search channels..."
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:maxLines="1"
                android:imeOptions="actionSearch"
                android:inputType="text" />

        </LinearLayout>

        <!-- Body: categories (left, full height) + guide rows (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Category list - permanent left column, full height -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/iptv_group_list"
                android:layout_width="220dp"
                android:layout_height="match_parent"
                android:background="#161616"
                android:scrollbars="none"
                android:paddingTop="8dp" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#222222" />

            <!-- Right side: timeline header + channel guide rows -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Timeline hour markers -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:background="#1A1A1A">

                    <LinearLayout
                        android:id="@+id/epg_timeline_header"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:paddingStart="160dp" />

                </FrameLayout>

                <!-- Channel guide rows: logo+number left, scrolling EPG strip right -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/iptv_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="none"
                    android:clipToPadding="false" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>


    <!-- Now-playing info card - floats top-right when guide is open -->
    <LinearLayout
        android:id="@+id/iptv_pip_container"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="56dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:background="#EE111111"
        android:padding="10dp"
        android:elevation="10dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/pip_logo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="centerInside"
                android:background="#1AFFFFFF"
                android:contentDescription="@string/poster_desc"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/pip_channel_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:ellipsize="end"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE"
                        android:textColor="#FFFFFF"
                        android:textSize="8sp"
                        android:background="#E50914"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="1dp"
                        android:paddingBottom="1dp"
                        android:layout_marginStart="4dp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/pip_epg_now"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/pip_epg_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="6dp"
            android:progressTint="#E50914"
            android:max="100"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/pip_epg_next"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="9sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="3dp"
            android:visibility="gone"/>

    </LinearLayout>

</RelativeLayout>
