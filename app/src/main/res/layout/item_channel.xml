<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:focusable="true"
    android:focusableInTouchMode="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@drawable/nav_item_focus_bg">

        <!-- Fixed left: number + logo + name -->
        <LinearLayout
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="#1A1A1A">

            <TextView
                android:id="@+id/channel_number"
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="11sp"
                android:gravity="center"/>

            <ImageView
                android:id="@+id/channel_logo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:scaleType="centerInside"
                android:background="#1AFFFFFF"
                android:contentDescription="@string/poster_desc"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/channel_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/channel_drm_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DRM"
                    android:textColor="#FFFFFF"
                    android:textSize="7sp"
                    android:background="#E50914"
                    android:paddingStart="3dp"
                    android:paddingEnd="3dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#222222"/>

        <!-- Scrollable EPG timeline strip for this channel -->
        <HorizontalScrollView
            android:id="@+id/epg_scroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/epg_strip"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"/>

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Focus border overlay - sits on top of everything -->
    <View
        android:id="@+id/channel_focus_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

</FrameLayout>
