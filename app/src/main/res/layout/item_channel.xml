<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="8dp"
    android:background="@drawable/nav_item_focus_bg"
    android:focusable="true"
    android:focusableInTouchMode="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/channel_number"
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="11sp"
            android:gravity="center"/>

        <ImageView
            android:id="@+id/channel_logo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:scaleType="centerInside"
            android:background="#1AFFFFFF"
            android:contentDescription="@string/poster_desc"/>

        <TextView
            android:id="@+id/channel_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/channel_drm_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DRM"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:background="#E50914"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:layout_marginStart="4dp"
            android:visibility="gone"/>
    </LinearLayout>

    <TextView
        android:id="@+id/epg_now"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#AAAAAA"
        android:textSize="9sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginTop="2dp"
        android:visibility="gone"/>

    <ProgressBar
        android:id="@+id/epg_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="1dp"
        android:progressTint="#E50914"
        android:max="100"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/epg_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#777777"
        android:textSize="8sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginTop="1dp"
        android:visibility="gone"/>

</LinearLayout>
