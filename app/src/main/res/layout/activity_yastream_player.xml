<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ExoPlayer surface — full screen, no padding -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/yastream_player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:show_subtitle_button="false"
        app:subtitle_bottom_padding_fraction="0.08"
        app:use_controller="true" />

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/yastream_loading"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="#E50914" />

    <!-- TOP BAR — overlays video, auto-hides after 3s -->
    <LinearLayout
        android:id="@+id/yastream_top_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="top"
        android:background="#BB000000"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:alpha="1">

        <TextView
            android:id="@+id/yastream_back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:padding="8dp"
            android:focusable="true"
            android:clickable="true" />

        <TextView
            android:id="@+id/yastream_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:singleLine="true"
            android:paddingStart="12dp" />

        <TextView
            android:id="@+id/yastream_cc_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CC"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="8dp"
            android:focusable="true"
            android:clickable="true" />

        <TextView
            android:id="@+id/yastream_change_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change Source"
            android:textColor="#E50914"
            android:textSize="13sp"
            android:padding="8dp"
            android:focusable="true"
            android:clickable="true" />

    </LinearLayout>

    <!-- Status text (buffering info) -->
    <TextView
        android:id="@+id/yastream_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="56dp"
        android:textColor="#CCFFFFFF"
        android:textSize="13sp"
        android:background="#66000000"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:visibility="gone" />

    <!-- Error overlay -->
    <LinearLayout
        android:id="@+id/yastream_error_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="gone"
        android:padding="32dp">

        <TextView
            android:text="⚠"
            android:textSize="48sp"
            android:textColor="#E50914"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:id="@+id/yastream_error_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/yastream_retry_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try Another Source"
            android:textColor="#FFFFFF"
            android:background="#E50914"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:textSize="14sp"
            android:focusable="true"
            android:clickable="true" />

    </LinearLayout>

</FrameLayout>
