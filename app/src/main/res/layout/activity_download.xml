<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/download_topbar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_secondary">

        <TextView
            android:id="@+id/download_back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:padding="8dp"
            android:focusable="true"
            android:background="@drawable/nav_item_focus_bg" />

        <TextView
            android:id="@+id/download_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:paddingStart="16dp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/download_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_below="@id/download_topbar"
        android:progressTint="@color/neon_red"
        android:max="100" />

    <WebView
        android:id="@+id/download_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/download_topbar" />

</RelativeLayout>
