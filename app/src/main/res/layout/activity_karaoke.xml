<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- ── Top bar ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp"
        android:background="#1A1A1A">

        <TextView
            android:id="@+id/karaoke_back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="8dp"
            android:focusable="true"
            android:background="@drawable/nav_item_focus_bg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎤  Karaoke"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingEnd="44dp" />

    </LinearLayout>

    <!-- ── Search bar ──────────────────────────────────────────────────── -->
    <EditText
        android:id="@+id/karaoke_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:layout_marginHorizontal="16dp"
        android:hint="Search title or artist..."
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:singleLine="true"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:background="@drawable/search_input_bg" />

    <!-- ── Song list — fills the rest of the screen ───────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/karaoke_song_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="108dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false" />

    <ProgressBar
        android:id="@+id/karaoke_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center" />

    <TextView
        android:id="@+id/karaoke_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:visibility="gone" />

</FrameLayout>
