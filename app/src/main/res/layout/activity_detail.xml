<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Backdrop -->
    <ImageView
        android:id="@+id/detail_backdrop"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/backdrop_desc" />

    <!-- Backdrop gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/detail_backdrop_gradient" />

    <!-- Back button -->
    <TextView
        android:id="@+id/detail_back_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Back"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:padding="16dp"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_margin="8dp"
        android:background="@drawable/nav_item_focus_bg" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/detail_backdrop"
        android:layout_marginTop="-60dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- Poster -->
            <ImageView
                android:id="@+id/detail_poster"
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:scaleType="centerCrop"
                android:background="@drawable/card_background"
                android:elevation="8dp"
                android:contentDescription="@string/poster_desc" />

            <!-- Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="20dp">

                <TextView
                    android:id="@+id/detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detail_tagline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp"
                    android:textStyle="italic"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/detail_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/neon_gold"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ·  "
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/detail_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ·  "
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/detail_runtime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/detail_genres"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/neon_blue"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/detail_overview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.3"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:layout_marginTop="8dp" />

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/detail_play_btn"
                        android:layout_width="160dp"
                        android:layout_height="48dp"
                        android:text="▶  PLAY NOW"
                        android:textColor="@color/bg_primary"
                        android:backgroundTint="@color/neon_red"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:focusable="true"
                        style="@style/Widget.NeroFlix.Button.Primary" />

                    <Button
                        android:id="@+id/detail_download_btn"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="⬇ DOWNLOAD"
                        android:layout_marginStart="0dp"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/text_primary"
                        android:backgroundTint="@color/bg_card"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:focusable="true"
                        style="@style/Widget.NeroFlix.Button.Secondary" />

                    <Button
                        android:id="@+id/detail_watchlist_btn"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="+ Watchlist"
                        android:textColor="@color/text_primary"
                        android:backgroundTint="@color/bg_secondary"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        android:focusable="true"
                        style="@style/Widget.NeroFlix.Button.Secondary" />

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/detail_progress"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:indeterminateTint="@color/neon_red"
        android:visibility="gone" />

</RelativeLayout>
