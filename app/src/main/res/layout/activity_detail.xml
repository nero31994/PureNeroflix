<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- Fullscreen backdrop -->
    <ImageView
        android:id="@+id/detail_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.35"
        android:contentDescription="@string/backdrop_desc"/>

    <!-- Gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/detail_backdrop_gradient"/>

    <!-- Back button -->
    <TextView
        android:id="@+id/detail_back_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Back"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="12dp"
        android:layout_margin="16dp"
        android:background="@drawable/nav_item_focus_bg"
        android:focusable="true"
        android:focusableInTouchMode="false"/>

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="48dp"
        android:paddingTop="32dp"
        android:gravity="center_vertical">

        <!-- Poster -->
        <ImageView
            android:id="@+id/detail_poster"
            android:layout_width="200dp"
            android:layout_height="300dp"
            android:scaleType="centerCrop"
            android:elevation="12dp"
            android:contentDescription="@string/poster_desc"/>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="40dp">

            <!-- Title + Rating -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/detail_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#FFFFFF"
                    android:textSize="36sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="16dp">
                    <TextView
                        android:id="@+id/detail_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F5C518"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ★"
                        android:textColor="#F5C518"
                        android:textSize="24sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Meta -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <TextView
                    android:id="@+id/detail_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ·  "
                    android:textColor="#666666"/>
                <TextView
                    android:id="@+id/detail_runtime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:visibility="gone"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ·  "
                    android:textColor="#666666"/>
                <TextView
                    android:id="@+id/detail_genres"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Red divider -->
            <View
                android:layout_width="48dp"
                android:layout_height="2dp"
                android:background="#E50914"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Tagline -->
            <TextView
                android:id="@+id/detail_tagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="13sp"
                android:textStyle="italic"
                android:visibility="gone"/>

            <!-- Overview -->
            <TextView
                android:id="@+id/detail_overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:maxLines="4"
                android:ellipsize="end"
                android:layout_marginTop="8dp"/>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <Button
                    android:id="@+id/detail_play_btn"
                    android:layout_width="160dp"
                    android:layout_height="48dp"
                    android:text="▶  PLAY NOW"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:focusable="true"
                    style="@style/Widget.NeroFlix.Button.Primary"/>

                <Button
                    android:id="@+id/detail_watchlist_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="+ Watchlist"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#33FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginStart="12dp"
                    android:focusable="true"
                    style="@style/Widget.NeroFlix.Button.Secondary"/>

                <Button
                    android:id="@+id/detail_download_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="⬇ Download"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#33FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginStart="12dp"
                    android:focusable="true"
                    style="@style/Widget.NeroFlix.Button.Secondary"/>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/detail_progress"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_centerInParent="true"
        android:indeterminateTint="@color/neon_red"
        android:visibility="gone"/>

</RelativeLayout>
