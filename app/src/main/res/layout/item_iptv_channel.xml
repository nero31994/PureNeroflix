<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:background="@drawable/nav_item_focus_bg">

    <!-- Channel number -->
    <TextView
        android:id="@+id/ch_number"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:textColor="#888888"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginEnd="8dp" />

    <!-- Channel logo -->
    <ImageView
        android:id="@+id/ch_logo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="fitCenter"
        android:layout_marginEnd="10dp"
        android:background="#1A1A1A"
        android:contentDescription="Channel logo" />

    <!-- Name + group stacked vertically -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/ch_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/ch_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#666688"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</LinearLayout>
