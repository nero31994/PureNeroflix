<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Compact Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#111111"
        android:paddingStart="8dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/kisskh_back"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:src="@drawable/ic_arrow_back"
            android:padding="10dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Compact search bar inline in header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_toEndOf="@id/kisskh_back"
            android:layout_toStartOf="@+id/kisskh_sort"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:background="#222222"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"
            android:layout_marginEnd="8dp">

            <EditText
                android:id="@+id/kisskh_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search..."
                android:textColorHint="#666666"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"/>

            <TextView
                android:id="@+id/kisskh_search_clear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="#888888"
                android:textSize="12sp"
                android:padding="4dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

        <TextView
            android:id="@+id/kisskh_sort"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Sort"
            android:textColor="#E50914"
            android:textSize="12sp"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"/>

    </RelativeLayout>

    <!-- Count badge row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#0A0A0A"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/kisskh_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- Grid -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/kisskh_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="3dp"
            android:clipToPadding="false"/>

        <ProgressBar
            android:id="@+id/kisskh_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#E50914"
            android:visibility="gone"/>

    </FrameLayout>

</LinearLayout>
