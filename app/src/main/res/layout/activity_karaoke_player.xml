<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- ── Background video — shuffled loop from assets/bgv, muted ──────── -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/karplay_bg_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0A0A0A"
        app:use_controller="false"
        app:resize_mode="zoom"
        app:surface_type="surface_view" />

    <!-- ── Top bar ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp">

        <TextView
            android:id="@+id/karplay_back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="8dp"
            android:focusable="true"
            android:background="@drawable/nav_item_focus_bg" />

        <TextView
            android:id="@+id/karplay_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingHorizontal="12dp" />

        <TextView
            android:id="@+id/karplay_play_pause_btn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="⏸"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:focusable="true"
            android:background="@drawable/nav_item_focus_bg" />

    </LinearLayout>

    <!-- ── Loading state ───────────────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/karplay_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="#E50914" />

    <!-- ── Lyric stage — centered, fills most of the screen ───────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="40dp">

        <TextView
            android:id="@+id/karplay_lyric_row_a"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:shadowColor="#000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8" />

        <TextView
            android:id="@+id/karplay_lyric_row_b"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:shadowColor="#000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8" />

    </LinearLayout>

    <!-- ── Floating lyric-sync controls — for touch devices; D-pad
         Left/Right still works exactly as before for remote users.
         Both paths call the same adjustLyricOffset() method, so
         behavior and persistence are identical either way. ─────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/nav_item_focus_bg"
        android:paddingHorizontal="6dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/karplay_sync_earlier_btn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="◀"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:focusable="true"
            android:contentDescription="Lyrics earlier"
            android:background="@drawable/nav_item_focus_bg" />

        <TextView
            android:id="@+id/karplay_sync_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sync"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:paddingHorizontal="8dp" />

        <TextView
            android:id="@+id/karplay_sync_later_btn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="▶"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:focusable="true"
            android:contentDescription="Lyrics later"
            android:background="@drawable/nav_item_focus_bg" />

    </LinearLayout>

</FrameLayout>
