<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape><solid android:color="#33E50914"/><stroke android:width="1dp" android:color="#E50914"/><corners android:radius="4dp"/></shape>
    </item>
    <item android:state_pressed="true">
        <shape><solid android:color="#4DE50914"/><corners android:radius="4dp"/></shape>
    </item>
    <item><shape><solid android:color="#00000000"/></shape></item>
</selector>
