<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- TOP FILTER BAR -->
    <HorizontalScrollView
        android:id="@+id/filter_bar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@color/bg_secondary"
        android:scrollbars="none"
        android:elevation="2dp">

        <LinearLayout
            android:id="@+id/filter_bar_inner"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/filter_popular"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Popular"
                android:textColor="@color/bg_primary"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:background="@drawable/filter_chip_active"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filter_top_rated"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Top Rated"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:background="@drawable/filter_chip_inactive"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filter_now_playing"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Now Playing"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:background="@drawable/filter_chip_inactive"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filter_upcoming"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Upcoming"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:background="@drawable/filter_chip_inactive" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- MAIN CONTENT -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- SCROLLABLE CONTENT -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/main_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Network logos row -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Popular Networks"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingStart="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/network_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clipToPadding="false"
                    android:layout_marginBottom="8dp" />

                <!-- Category rows -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/main_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="16dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerInParent="true"
            android:indeterminateTint="@color/neon_red"
            android:visibility="gone" />

        <!-- Hidden hero stubs -->
        <RelativeLayout
            android:id="@+id/hero_section"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone">
            <ImageView android:id="@+id/hero_backdrop" android:layout_width="0dp" android:layout_height="0dp" android:contentDescription="@string/hero_backdrop_desc"/>
            <TextView android:id="@+id/hero_title" android:layout_width="0dp" android:layout_height="0dp"/>
            <TextView android:id="@+id/hero_rating" android:layout_width="0dp" android:layout_height="0dp"/>
            <TextView android:id="@+id/hero_year" android:layout_width="0dp" android:layout_height="0dp"/>
            <TextView android:id="@+id/hero_overview" android:layout_width="0dp" android:layout_height="0dp"/>
            <Button android:id="@+id/hero_play_btn" android:layout_width="0dp" android:layout_height="0dp"/>
            <Button android:id="@+id/hero_info_btn" android:layout_width="0dp" android:layout_height="0dp"/>
        </RelativeLayout>

    </RelativeLayout>

    <!-- BOTTOM NAVIGATION BAR -->
    <LinearLayout
        android:id="@+id/left_sidebar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/bg_secondary"
        android:gravity="center"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/nav_search"
            android:layout_width="44dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/ic_search"
            android:padding="10dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:background="@drawable/nav_item_focus_bg"
            android:layout_marginEnd="8dp"
            android:contentDescription="Search" />

        <ImageView
            android:id="@+id/nav_movies"
            android:layout_width="44dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/ic_movies"
            android:padding="10dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:background="@drawable/nav_item_focus_bg"
            android:layout_marginEnd="8dp"
            android:contentDescription="Movies" />

        <ImageView
            android:id="@+id/nav_tv"
            android:layout_width="44dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/ic_tv"
            android:padding="10dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:background="@drawable/nav_item_focus_bg"
            android:layout_marginEnd="8dp"
            android:contentDescription="TV Shows" />

        <ImageView
            android:id="@+id/nav_anime"
            android:layout_width="44dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/ic_anime"
            android:padding="10dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:background="@drawable/nav_item_focus_bg"
            android:layout_marginEnd="8dp"
            android:contentDescription="Anime" />

        <ImageView
            android:id="@+id/nav_watchlist"
            android:layout_width="44dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/ic_watchlist"
            android:padding="10dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:background="@drawable/nav_item_focus_bg"
            android:layout_marginEnd="8dp"
            android:contentDescription="Watchlist" />

        <ImageView
            android:id="@+id/nav_history"
            android:layout_width="44dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/ic_history"
            android:padding="10dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:background="@drawable/nav_item_focus_bg"
            android:layout_marginEnd="8dp"
            android:contentDescription="History" />

        <ImageView
            android:id="@+id/nav_downloads"
            android:layout_width="44dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/ic_download"
            android:padding="10dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:background="@drawable/nav_item_focus_bg"
            android:layout_marginEnd="8dp"
            android:contentDescription="Downloads" />

        <ImageView
            android:id="@+id/nav_iptv"
            android:layout_width="@dimen/nav_icon_size"
            android:layout_height="@dimen/nav_icon_size"
            android:src="@drawable/ic_iptv"
            android:padding="@dimen/nav_icon_padding"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:background="@drawable/nav_item_focus_bg"
            android:layout_marginBottom="@dimen/nav_icon_margin"
            android:contentDescription="IPTV" />

        <ImageView
            android:id="@+id/nav_genre"
            android:layout_width="44dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@drawable/ic_genre"
            android:padding="10dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:background="@drawable/nav_item_focus_bg"
            android:contentDescription="Genre" />

    </LinearLayout>

</LinearLayout>
